# ============================================
# MeuZapDesk — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ============================================

# --- PostgreSQL ---
POSTGRES_DB=meuzapdesk
POSTGRES_USER=meuzapdesk
POSTGRES_PASSWORD=senha_segura_aqui

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=senha_n8n_aqui
N8N_HOST=n8n.seudominio.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.seudominio.com

# --- Next.js / NextAuth ---
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32
NEXTAUTH_URL=https://painel.seudominio.com

# --- WhatsApp Business API (Meta) ---
WA_PHONE_NUMBER_ID=seu_phone_number_id
WA_ACCESS_TOKEN=seu_token_de_acesso_permanente
WA_VERIFY_TOKEN=token_secreto_para_validar_webhook

# --- Limites de Alerta (minutos) ---
ALERT_WARN_MINUTES=5
ALERT_URGENT_MINUTES=15
