# ============================================
# MeuZapDesk — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ============================================

# --- PostgreSQL ---
POSTGRES_DB=meuzapdesk
POSTGRES_USER=meuzapdesk
POSTGRES_PASSWORD=senha_segura_aqui

# --- Next.js / NextAuth ---
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32
NEXTAUTH_URL=https://painel.seudominio.com

# --- WAHA (WhatsApp HTTP API) ---
# Chave de autenticação da API do WAHA (crie um valor aleatório e seguro)
WAHA_API_KEY=sua_chave_waha_aqui

# Token secreto para validar os webhooks recebidos do WAHA
# O WAHA chamará: https://painel.seudominio.com/api/webhook/whatsapp?secret=ESSE_VALOR
WAHA_WEBHOOK_SECRET=token_secreto_webhook_aqui

# --- Limites de Alerta (minutos) ---
ALERT_WARN_MINUTES=5
ALERT_URGENT_MINUTES=15
