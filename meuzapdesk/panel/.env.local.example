# ============================================================
# .env.local — Desenvolvimento Local (Next.js fora do Docker)
# Copie para .env.local: cp .env.local.example .env.local
# ============================================================

# Banco de dados (PostgreSQL via docker-compose.dev.yml)
DATABASE_URL="postgresql://meuzapdesk:devsenha123@localhost:5432/meuzapdesk_dev"

# NextAuth
NEXTAUTH_SECRET="dev-secret-troque-em-producao-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Redis (via docker-compose.dev.yml)
REDIS_URL="redis://localhost:6379"

# WhatsApp Business API — deixe vazio em dev local
# O painel funciona normalmente; apenas o envio/recebimento real de mensagens
# exige credenciais válidas da Meta.
WA_PHONE_NUMBER_ID=""
WA_ACCESS_TOKEN=""
WA_VERIFY_TOKEN="dev-verify-token"

# n8n (não necessário no dev local)
N8N_WEBHOOK_URL="http://localhost:5678"

# Alertas de SLA (minutos)
ALERT_WARN_MINUTES=5
ALERT_URGENT_MINUTES=15
