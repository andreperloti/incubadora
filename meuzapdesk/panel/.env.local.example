# ============================================================
# .env.local — Desenvolvimento Local (Next.js fora do Docker)
# Copie para .env.local: cp .env.local.example .env.local
# ============================================================

# Banco de dados (PostgreSQL via docker-compose.dev.yml)
DATABASE_URL="postgresql://meuzapdesk:devsenha123@localhost:5433/meuzapdesk_dev"

# NextAuth
NEXTAUTH_SECRET="dev-secret-troque-em-producao-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Redis (via docker-compose.dev.yml)
REDIS_URL="redis://localhost:6379"

# WAHA (WhatsApp HTTP API — via docker-compose.dev.yml)
# Em dev, o WAHA roda em localhost:3002
WAHA_API_URL="http://localhost:3002"
WAHA_API_KEY="dev-waha-key"
WAHA_WEBHOOK_SECRET="dev-webhook-secret"

# Alertas de SLA (minutos)
ALERT_WARN_MINUTES=5
ALERT_URGENT_MINUTES=15
